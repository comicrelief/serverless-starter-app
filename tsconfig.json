{
  "compilerOptions": {
    "preserveConstEnums": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "allowJs": true,
    "target": "es2023",
    "module": "nodenext",
    "lib": [
      "es2023"
    ],
    "types": ["node", "jest"],
    "outDir": ".build",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "rootDir": ".",
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  },
  "include": [
    "src/**/*.ts",
    "*.d.ts",
    "handler.ts"
  ],
  // "exclude": [
  //   "jest.config.ts"
  // ]
}
